  m_Script: {fileID: 11500000, guid: df8a209b35f16a044afbe613afbfdcdc, type: 3}
  m_Name: Naar huis
  m_EditorClassIdentifier: 
  titel: 
  beschrijving: Je bent helemaal klaar! Je mag weer naar huis of terug naar school.
    De dokter kijkt later naar de plaatjes en vertelt wat ze betekenen. Jij hoeft
    verder niets meer te doen.
  leukWeetje: "Leuk weetje: MRI\u2019s worden ook gebruikt om te zien hoe hersenen
    werken als mensen nadenken, muziek luisteren of puzzels maken. Het is alsof de
    scanner kan meekijken hoe je brein bezig is."
